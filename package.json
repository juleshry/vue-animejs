{
  "name": "@juleshry/vue-animejs",
  "version": "0.1.0",
  "description": "Vue 3 composables for Anime.js v4 — reactive animations that integrate naturally with Vue's reactivity system and component lifecycle.",
  "keywords": [
    "animation",
    "animejs",
    "composable",
    "composables",
    "vue",
    "vue3"
  ],
  "homepage": "https://github.com/juleshry/vue-animejs#readme",
  "bugs": {
    "url": "https://github.com/juleshry/vue-animejs/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/juleshry/vue-animejs.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/core": ">=14",
    "animejs": ">=4",
    "happy-dom": "^20.9.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vue": ">=3.5",
    "vue-tsc": "^3.2.6"
  },
  "peerDependencies": {
    "@vueuse/core": ">=14",
    "animejs": ">=4",
    "vue": ">=3.5"
  }
}