{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@lib": ["./src/index.ts"]
    }
  },
  "include": ["vite.config.ts", "src/**/*", "playground/**/*"]
}
